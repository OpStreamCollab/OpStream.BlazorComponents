@typeparam TModel
@using System.Text
@using System.Text.Json
@using System.Text.Json.Nodes
@using Microsoft.AspNetCore.Components.Forms
@using OpStream.Client.Transports
@using OpStream.Shared.Messages
@implements ICollabFormContext
@implements IAsyncDisposable
@inject IOpStreamClient Client
@inject IJSRuntime JS

<div class="collab-bar">
    <span class="collab-status @(_joined ? "ok" : "wait")">@_statusMessage</span>
    <span class="collab-rev">doc: <code>@DocumentId</code> · rev: <code>@_currentRevision</code></span>

    @if (ShowConnectedUsers)
    {
        <span class="collab-avatars">
            @foreach (var p in _peers.Values)
            {
                <span class="peer-avatar" style="background:@p.Color" title="@p.Name">@Initials(p.Name)</span>
            }
            @if (_joined)
            {
                <span class="peer-avatar me" style="background:@_myColor;color:@_myColor" title="@_myName (you)">@Initials(_myName)</span>
            }
        </span>
    }
    else
    {
        <span class="collab-peers">
            @foreach (var p in _peers.Values)
            {
                <span class="peer-dot" style="background:@p.Color" title="@p.Name"></span>
            }
            @if (_joined)
            {
                <span class="peer-dot me" style="background:@_myColor" title="@_myName (you)"></span>
            }
        </span>
    }

    @if (!string.IsNullOrEmpty(_lastActivity))
    {
        <span class="collab-activity">@_lastActivity</span>
    }

    @if (AllowComments)
    {
        <button class="collab-comment-btn"
                disabled="@(string.IsNullOrEmpty(_editingField))"
                title="@(string.IsNullOrEmpty(_editingField) ? "Focus a field to add a comment" : $"Add comment to {Humanize(_editingField)}")"
                @onclick="OpenNewCommentDialog">✉</button>
    }
</div>

<EditForm EditContext="_editContext" OnValidSubmit="@(() => OnValidSubmit.InvokeAsync())">
    <DataAnnotationsValidator />
    <fieldset disabled="@(!_joined)" class="collab-fieldset">
        <CascadingValue Value="(ICollabFormContext)this" IsFixed="true">
            @ChildContent
        </CascadingValue>
    </fieldset>
</EditForm>

@if (_showNewCommentDialog)
{
    <div class="collab-dialog-overlay" @onclick="CloseNewCommentDialog">
        <div class="collab-dialog" @onclick:stopPropagation>
            <h4 class="collab-dialog-title">Add comment — @Humanize(_commentDialogField)</h4>
            <textarea class="collab-dialog-textarea" @bind="_newCommentBody" placeholder="Write a comment…"></textarea>
            <div class="collab-dialog-actions">
                <button class="collab-btn collab-btn-primary"
                        disabled="@(string.IsNullOrWhiteSpace(_newCommentBody))"
                        @onclick="SubmitNewCommentAsync">Send</button>
                <button class="collab-btn" @onclick="CloseNewCommentDialog">Cancel</button>
            </div>
        </div>
    </div>
}

@if (_showFieldCommentsDialog && !string.IsNullOrEmpty(_viewingField))
{
    var fieldComments = CommentsForField(_viewingField);
    var roots = fieldComments.Where(c => c.ParentCommentId is null).ToList();
    <div class="collab-dialog-overlay" @onclick="CloseFieldCommentsDialog">
        <div class="collab-dialog collab-dialog-wide" @onclick:stopPropagation>
            <h4 class="collab-dialog-title">Comments — @Humanize(_viewingField)</h4>
            @if (!roots.Any())
            {
                <p class="collab-no-comments">No comments yet.</p>
            }
            @foreach (var root in roots)
            {
                var replies = fieldComments.Where(c => c.ParentCommentId == root.Id).ToList();
                <div class="collab-comment">
                    <div class="collab-comment-body">@root.Body</div>
                    <div class="collab-comment-meta">@root.CreatedAt.ToString("g")</div>
                    @foreach (var reply in replies)
                    {
                        <div class="collab-comment collab-comment-reply">
                            <div class="collab-comment-body">@reply.Body</div>
                            <div class="collab-comment-meta">@reply.CreatedAt.ToString("g")</div>
                        </div>
                    }
                    <div class="collab-reply-row">
                        <input class="collab-reply-input" placeholder="Reply…"
                               value="@GetReply(root.Id)"
                               @oninput="e => SetReply(root.Id, e.Value?.ToString() ?? string.Empty)" />
                        <button class="collab-btn collab-btn-small collab-btn-primary"
                                @onclick="() => SubmitReplyAsync(root.Id)">Reply</button>
                    </div>
                </div>
            }
            <div class="collab-dialog-actions">
                <button class="collab-btn" @onclick="CloseFieldCommentsDialog">Close</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public string DocumentId { get; set; } = "";
    [Parameter] public string DocumentType { get; set; } = "form";
    [Parameter, EditorRequired] public TModel Model { get; set; } = default!;
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback OnValidSubmit { get; set; }
    [Parameter] public bool ShowConnectedUsers { get; set; } = false;
    [Parameter] public bool AllowComments { get; set; } = false;

    public event Action? StateChanged;
    public bool Joined => _joined;

    private static readonly string[] Palette =
    {
        "#e57373","#64b5f6","#81c784","#ffb74d","#ba68c8","#4db6ac",
        "#f06292","#9575cd","#7986cb","#a1887f","#90a4ae","#dce775",
    };

    private static readonly JsonSerializerOptions JsonOptions = new()
    {
        PropertyNameCaseInsensitive = true,
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
    };

    private EditContext? _editContext;
    private bool _joined;
    private bool _started;
    private long _currentRevision;
    private string _statusMessage = "Connecting…";

    private readonly string _peerId = $"peer-{Guid.NewGuid():N}";
    private string _myName = "Anonymous";
    private string _myColor = Palette[0];
    private string _lastActivity = "";
    private string _editingField = "";

    private readonly Dictionary<string, PeerInfo> _peers = new(StringComparer.Ordinal);

    // ── Comments ──────────────────────────────────────────────────────────────────
    private readonly Dictionary<string, List<CommentDto>> _commentsByField = new(StringComparer.Ordinal);
    private readonly Dictionary<string, string> _replyBodies = new(StringComparer.Ordinal);
    private bool _showNewCommentDialog;
    private bool _showFieldCommentsDialog;
    private string _newCommentBody = "";
    private string _commentDialogField = "";
    private string _viewingField = "";

    protected override void OnParametersSet()
    {
        if (_editContext is null || !ReferenceEquals(_editContext.Model, Model))
        {
            if (_editContext is not null) _editContext.OnFieldChanged -= HandleFieldChanged;
            _editContext = new EditContext(Model!);
            _editContext.OnFieldChanged += HandleFieldChanged;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _started) return;
        _started = true;

        var name = await JS.InvokeAsync<string?>("prompt", "What name should others see?", "");
        _myName = string.IsNullOrWhiteSpace(name) ? "Anonymous" : name.Trim();
        _myColor = PickColor(_myName);

        await ConnectAsync();
    }

    private async Task ConnectAsync()
    {
        Client.OnReceiveOp += HandleRemoteOpAsync;
        Client.OnReceiveAwareness += HandleAwarenessAsync;
        Client.OnPeerDisconnected += HandlePeerDisconnected;
        Client.OnDisconnected += HandleTransportClosed;

        if (AllowComments)
        {
            Client.OnCommentCreated += HandleCommentCreatedAsync;
            Client.OnCommentUpdated += HandleCommentUpdatedAsync;
            Client.OnCommentDeleted += HandleCommentDeletedAsync;
        }

        try
        {
            var join = await Client.ConnectAndJoinAsync(DocumentId, DocumentType);
            _currentRevision = join.Revision;

            LoadSnapshot(join.Snapshot);
            foreach (var state in join.Awareness) ApplyAwareness(state);

            _joined = true;
            _statusMessage = "Connected";

            await PublishAwarenessAsync("joined");

            if (AllowComments)
            {
                try
                {
                    var comments = await Client.ListOpenCommentsAsync(DocumentId);
                    foreach (var c in comments) AddOrUpdateComment(c);
                }
                catch (NotSupportedException) { /* transport does not expose comments */ }
                catch (Exception ex) { Console.Error.WriteLine($"ListComments failed: {ex.Message}"); }
            }

            NotifyStateChanged();
        }
        catch (Exception ex)
        {
            _statusMessage = $"Error: {ex.Message}";
            NotifyStateChanged();
        }
    }

    // ── EditContext → server ──────────────────────────────────────────────────────

    private async void HandleFieldChanged(object? sender, FieldChangedEventArgs e)
    {
        try { await SendFieldAsync(e.FieldIdentifier.FieldName); }
        catch (Exception ex) { Console.Error.WriteLine($"Field sync failed: {ex.Message}"); }
    }

    private async Task SendFieldAsync(string fieldName)
    {
        if (!_joined) return;

        var prop = Model!.GetType().GetProperty(fieldName);
        if (prop is null) return;

        var node = ToNode(prop.GetValue(Model));
        var op = new JsonObject
        {
            ["$type"] = node is null ? "clr" : "set",
            ["fieldName"] = fieldName,
        };
        if (node is not null) op["value"] = node;
        op["timestamp"] = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
        op["peerId"] = _peerId;

        var batch = new JsonObject { ["operations"] = new JsonArray(op) };
        var payload = Encoding.UTF8.GetBytes(batch.ToJsonString());

        try
        {
            var result = await Client.SendOpAsync(DocumentId, payload, _currentRevision);
            if (result.Success)
            {
                _currentRevision = result.NewRevision;
                await PublishAwarenessAsync($"edited {Humanize(fieldName)}");
                NotifyStateChanged();
            }
            else
            {
                Console.Error.WriteLine($"SendOp rejected: {result.ErrorMessage}");
            }
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"SendOp failed: {ex.Message}");
        }
    }

    // ── Server → model ────────────────────────────────────────────────────────────

    private Task HandleRemoteOpAsync(ReadOnlyMemory<byte> payload, long newRevision)
    {
        _currentRevision = newRevision;

        using var doc = JsonDocument.Parse(payload);
        if (doc.RootElement.TryGetProperty("operations", out var ops))
        {
            foreach (var op in ops.EnumerateArray())
            {
                if (!op.TryGetProperty("fieldName", out var fn)) continue;
                var fieldName = fn.GetString();
                if (fieldName is null) continue;

                if (op.TryGetProperty("value", out var value))
                    ApplyToModel(fieldName, value);
                else
                    ApplyToModel(fieldName, null);
            }
        }

        NotifyStateChanged();
        return Task.CompletedTask;
    }

    private Task HandleAwarenessAsync(IEnumerable<AwarenessState> states)
    {
        foreach (var state in states) ApplyAwareness(state);
        NotifyStateChanged();
        return Task.CompletedTask;
    }

    private void HandlePeerDisconnected(string peerId)
    {
        _peers.Remove(peerId);
        NotifyStateChanged();
    }

    private void HandleTransportClosed(Exception? ex)
    {
        _joined = false;
        _statusMessage = ex is null ? "Disconnected" : $"Disconnected: {ex.Message}";
        NotifyStateChanged();
    }

    private void LoadSnapshot(ReadOnlyMemory<byte> snapshot)
    {
        if (snapshot.IsEmpty) return;
        using var doc = JsonDocument.Parse(snapshot);
        if (!doc.RootElement.TryGetProperty("fields", out var fields)) return;

        foreach (var field in fields.EnumerateObject())
        {
            if (field.Value.TryGetProperty("value", out var value))
                ApplyToModel(field.Name, value);
        }
    }

    private void ApplyToModel(string fieldName, JsonElement? valueOrNull)
    {
        var prop = Model!.GetType().GetProperty(fieldName);
        if (prop is null || !prop.CanWrite) return;

        bool isNull = valueOrNull is null || valueOrNull.Value.ValueKind == JsonValueKind.Null;
        if (isNull)
        {
            object? cleared = prop.PropertyType == typeof(string)
                ? string.Empty
                : (Nullable.GetUnderlyingType(prop.PropertyType) is null && prop.PropertyType.IsValueType
                    ? Activator.CreateInstance(prop.PropertyType)
                    : null);
            prop.SetValue(Model, cleared);
        }
        else
        {
            var converted = JsonSerializer.Deserialize(
                valueOrNull!.Value.GetRawText(), prop.PropertyType, OpStream.Constants.OpStreamJsonOptions.Default);
            prop.SetValue(Model, converted);
        }
    }

    // ── ICollabFormContext ────────────────────────────────────────────────────────

    public FieldEditor? EditorOf(string fieldName)
    {
        foreach (var p in _peers.Values)
        {
            if (string.Equals(p.EditingField, fieldName, StringComparison.Ordinal))
                return new FieldEditor(p.Name, p.Color);
        }
        return null;
    }

    public async Task NotifyFocusAsync(string fieldName)
    {
        _editingField = fieldName;
        await PublishAwarenessAsync($"is editing {Humanize(fieldName)}");
        await InvokeAsync(StateHasChanged);
    }

    public async Task NotifyBlurAsync(string fieldName)
    {
        if (_editingField == fieldName) _editingField = "";
        await PublishAwarenessAsync("");
        await InvokeAsync(StateHasChanged);
    }

    bool ICollabFormContext.AllowComments => AllowComments;

    IReadOnlyList<CommentDto> ICollabFormContext.CommentsForField(string fieldName) =>
        _commentsByField.TryGetValue(fieldName, out var list) ? list : Array.Empty<CommentDto>();

    void ICollabFormContext.OpenFieldComments(string fieldName)
    {
        _viewingField = fieldName;
        foreach (var c in CommentsForField(fieldName).Where(c => c.ParentCommentId is null))
            _replyBodies.TryAdd(c.Id, "");
        _showFieldCommentsDialog = true;
        InvokeAsync(StateHasChanged);
    }

    // Private helper so the template can call CommentsForField without explicit cast.
    private IReadOnlyList<CommentDto> CommentsForField(string fieldName) =>
        ((ICollabFormContext)this).CommentsForField(fieldName);

    // ── Comment events ────────────────────────────────────────────────────────────

    private Task HandleCommentCreatedAsync(CommentDto comment)
    {
        AddOrUpdateComment(comment);
        NotifyStateChanged();
        return Task.CompletedTask;
    }

    private Task HandleCommentUpdatedAsync(CommentDto comment)
    {
        AddOrUpdateComment(comment);
        NotifyStateChanged();
        return Task.CompletedTask;
    }

    private Task HandleCommentDeletedAsync(CommentDeletedDto dto)
    {
        foreach (var list in _commentsByField.Values)
            list.RemoveAll(c => c.Id == dto.CommentId);
        NotifyStateChanged();
        return Task.CompletedTask;
    }

    private void AddOrUpdateComment(CommentDto comment)
    {
        var fieldName = FieldFromAnchor(comment.Anchor);
        if (fieldName is null) return;

        if (!_commentsByField.TryGetValue(fieldName, out var list))
            _commentsByField[fieldName] = list = [];

        var idx = list.FindIndex(c => c.Id == comment.Id);
        if (idx >= 0) list[idx] = comment;
        else list.Add(comment);
    }

    private static string? FieldFromAnchor(AnchorDto? anchor)
    {
        if (anchor?.Kind != "field") return null;
        return anchor.Data.TryGetProperty("fieldName", out var fn) ? fn.GetString() : null;
    }

    // ── Comment dialog actions ────────────────────────────────────────────────────

    private void OpenNewCommentDialog()
    {
        _commentDialogField = _editingField;
        _newCommentBody = "";
        _showNewCommentDialog = true;
    }

    private void CloseNewCommentDialog() => _showNewCommentDialog = false;

    private async Task SubmitNewCommentAsync()
    {
        if (string.IsNullOrWhiteSpace(_newCommentBody)) return;

        var anchorData = JsonSerializer.SerializeToElement(new { fieldName = _commentDialogField }, JsonOptions);
        var cmd = new NewCommentCmd(_newCommentBody.Trim(), new AnchorDto("field", anchorData), null);

        try
        {
            var comment = await Client.CreateCommentAsync(DocumentId, cmd);
            AddOrUpdateComment(comment);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"CreateComment failed: {ex.Message}");
        }

        _showNewCommentDialog = false;
        NotifyStateChanged();
    }

    private void CloseFieldCommentsDialog() => _showFieldCommentsDialog = false;

    private async Task SubmitReplyAsync(string parentId)
    {
        if (!_replyBodies.TryGetValue(parentId, out var body) || string.IsNullOrWhiteSpace(body)) return;

        var cmd = new NewCommentCmd(body.Trim(), null, parentId);
        try
        {
            var comment = await Client.CreateCommentAsync(DocumentId, cmd);
            AddOrUpdateComment(comment);
            _replyBodies[parentId] = "";
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Reply failed: {ex.Message}");
        }

        NotifyStateChanged();
    }

    private string GetReply(string id) => _replyBodies.TryGetValue(id, out var v) ? v : "";
    private void SetReply(string id, string v) => _replyBodies[id] = v;

    // ── Awareness ─────────────────────────────────────────────────────────────────

    private async Task PublishAwarenessAsync(string action)
    {
        var payload = new AwarenessPayload(_myName, _myColor, action, _editingField, DateTimeOffset.UtcNow);
        var element = JsonSerializer.SerializeToElement(payload, JsonOptions);
        try { await Client.SendAwarenessAsync(DocumentId, element); }
        catch (Exception ex) { Console.Error.WriteLine($"SendAwareness failed: {ex.Message}"); }
    }

    private void ApplyAwareness(AwarenessState state)
    {
        if (state.PeerId == _peerId) return;

        string name = "anonymous", color = "#888", action = "", editingField = "";
        try
        {
            var payload = state.Data.Deserialize<AwarenessPayload>(JsonOptions);
            if (payload is not null)
            {
                name = payload.Name;
                color = payload.Color;
                action = payload.LastAction;
                editingField = payload.EditingField ?? "";
            }
        }
        catch { /* tolerate older / different shapes */ }

        if (!_peers.TryGetValue(state.PeerId, out var info))
        {
            info = new PeerInfo { PeerId = state.PeerId };
            _peers[state.PeerId] = info;
        }
        info.Name = name;
        info.Color = color;
        info.LastAction = action;
        info.EditingField = editingField;

        if (!string.IsNullOrEmpty(action))
            _lastActivity = $"{name} {action}";
    }

    // ── Helpers ───────────────────────────────────────────────────────────────────

    private void NotifyStateChanged()
    {
        StateChanged?.Invoke();
        InvokeAsync(StateHasChanged);
    }

    private static JsonNode? ToNode(object? value)
    {
        if (value is null) return null;
        if (value is string s) return string.IsNullOrEmpty(s) ? null : JsonValue.Create(s);
        return JsonSerializer.SerializeToNode(value, value.GetType(), OpStream.Constants.OpStreamJsonOptions.Default);
    }

    private static string Initials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{char.ToUpperInvariant(parts[0][0])}{char.ToUpperInvariant(parts[1][0])}"
            : name.Length >= 2 ? $"{char.ToUpperInvariant(name[0])}{char.ToUpperInvariant(name[1])}"
            : name.ToUpperInvariant();
    }

    private static string Humanize(string name)
    {
        var sb = new StringBuilder(name.Length + 4);
        for (int i = 0; i < name.Length; i++)
        {
            char c = name[i];
            if (i > 0 && char.IsUpper(c) && !char.IsUpper(name[i - 1])) sb.Append(' ');
            sb.Append(i == 0 ? char.ToUpperInvariant(c) : c);
        }
        return sb.ToString();
    }

    private static string PickColor(string seed)
    {
        unchecked
        {
            int hash = 17;
            foreach (var ch in seed) hash = hash * 31 + ch;
            return Palette[Math.Abs(hash) % Palette.Length];
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_editContext is not null) _editContext.OnFieldChanged -= HandleFieldChanged;

        Client.OnReceiveOp -= HandleRemoteOpAsync;
        Client.OnReceiveAwareness -= HandleAwarenessAsync;
        Client.OnPeerDisconnected -= HandlePeerDisconnected;
        Client.OnDisconnected -= HandleTransportClosed;

        if (AllowComments)
        {
            Client.OnCommentCreated -= HandleCommentCreatedAsync;
            Client.OnCommentUpdated -= HandleCommentUpdatedAsync;
            Client.OnCommentDeleted -= HandleCommentDeletedAsync;
        }

        try { await Client.DisposeAsync(); } catch { /* ignore */ }
    }

    private sealed class PeerInfo
    {
        public required string PeerId { get; init; }
        public string Name { get; set; } = "anonymous";
        public string Color { get; set; } = "#888";
        public string LastAction { get; set; } = "";
        public string EditingField { get; set; } = "";
    }

    private sealed record AwarenessPayload(string Name, string Color, string LastAction, string? EditingField, DateTimeOffset LastActionAt);
}

<style>
    .collab-bar {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.75rem;
        padding: 0.5rem 0.75rem;
        margin-bottom: 1.5rem;
        background: #f6f8fa;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        font-size: 0.85rem;
        color: #555;
    }

    .collab-status {
        font-weight: 600;
        padding: 0.15rem 0.5rem;
        border-radius: 999px;
    }
    .collab-status.ok { background: #d4edda; color: #155724; }
    .collab-status.wait { background: #fff3cd; color: #856404; }

    .collab-rev code { color: #007bff; }

    /* Small dot mode (ShowConnectedUsers = false, default) */
    .collab-peers { display: flex; align-items: center; gap: 0.3rem; }
    .peer-dot {
        width: 12px; height: 12px; border-radius: 50%;
        display: inline-block; border: 1px solid rgba(0,0,0,0.15);
    }
    .peer-dot.me { box-shadow: 0 0 0 2px #fff, 0 0 0 3px currentColor; }

    /* Avatar circle mode (ShowConnectedUsers = true) */
    .collab-avatars { display: flex; align-items: center; gap: 0.3rem; }
    .peer-avatar {
        width: 28px; height: 28px; border-radius: 50%;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 0.65rem; font-weight: 700; color: #fff;
        border: 1.5px solid rgba(0,0,0,0.15);
        cursor: default; user-select: none;
    }
    .peer-avatar.me { box-shadow: 0 0 0 2px #fff, 0 0 0 3.5px currentColor; }

    .collab-activity { margin-left: auto; font-style: italic; color: #888; }

    /* Comment envelope button */
    .collab-comment-btn {
        background: none;
        border: 1px solid #ccc;
        border-radius: 6px;
        padding: 0.15rem 0.55rem;
        cursor: pointer;
        font-size: 0.85rem;
        color: #555;
        transition: background 0.15s, border-color 0.15s;
    }
    .collab-comment-btn:hover:not(:disabled) { background: #e8f0fe; border-color: #a8c7fa; color: #1a73e8; }
    .collab-comment-btn:disabled { opacity: 0.4; cursor: not-allowed; }

    .collab-fieldset { border: none; padding: 0; margin: 0; min-inline-size: auto; }

    .collab-field {
        border: 2px solid transparent;
        border-radius: 8px;
        padding: 0.4rem 0.6rem;
        margin-bottom: 0.85rem;
        transition: border-color 0.15s, box-shadow 0.15s, background-color 0.15s;
    }

    .collab-field.locked {
        border-color: var(--lock-color, #888);
        background-color: color-mix(in srgb, var(--lock-color, #888) 8%, transparent);
        box-shadow: 0 0 0 2px color-mix(in srgb, var(--lock-color, #888) 25%, transparent);
    }

    .collab-field-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
        margin-bottom: 0.4rem;
    }

    .collab-field-head label {
        margin-bottom: 0;
        font-weight: 500;
        color: #555;
    }

    .lock-badge {
        font-size: 0.72rem;
        font-weight: 600;
        color: #fff;
        padding: 0.1rem 0.5rem;
        border-radius: 999px;
        white-space: nowrap;
    }

    /* Comment indicator button on each field */
    .collab-comment-indicator {
        background: none;
        border: none;
        padding: 0 0.2rem;
        cursor: pointer;
        font-size: 0.8rem;
        color: #888;
        line-height: 1;
        transition: color 0.15s;
    }
    .collab-comment-indicator:hover { color: #1a73e8; }

    .collab-field-inner {
        border: none;
        padding: 0;
        margin: 0;
        min-inline-size: auto;
    }

    .collab-field-inner:disabled { opacity: 0.85; }

    /* ── Dialogs ─────────────────────────────────────────────────────────────── */
    .collab-dialog-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.35);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
    }

    .collab-dialog {
        background: #fff;
        border-radius: 10px;
        padding: 1.5rem;
        min-width: 320px;
